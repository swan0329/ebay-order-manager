generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum EbayEnvironment {
  SANDBOX
  PRODUCTION
}

enum SyncStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum ShipmentStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  loginId   String   @unique @map("login_id")
  name      String?
  role      UserRole @default(ADMIN)
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ebayAccounts EbayAccount[]
  orders       Order[]
  listingTemplates ListingTemplate[]
  listingDrafts ListingDraft[]
  ebayPolicyCaches EbayPolicyCache[]
  ebayInventoryLocationCaches EbayInventoryLocationCache[]
  productMappings ProductMapping[]
  productUploadJobs ProductUploadJob[]
  syncLogs     SyncLog[]

  @@map("users")
}

model EbayAccount {
  id                    String          @id @default(cuid())
  userId                String          @map("user_id")
  ebayUserId            String?         @map("ebay_user_id")
  username              String?
  environment           EbayEnvironment @default(SANDBOX)
  scopes                String
  accessTokenEncrypted  String          @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String          @map("refresh_token_encrypted") @db.Text
  expiresAt             DateTime        @map("expires_at")
  refreshTokenExpiresAt DateTime?       @map("refresh_token_expires_at")
  rawProfile            Json?           @map("raw_profile")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([userId, environment, ebayUserId])
  @@map("ebay_accounts")
}

model Order {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  ebayAccountId     String?   @map("ebay_account_id")
  ebayOrderId       String    @map("ebay_order_id")
  orderStatus       String    @map("order_status")
  fulfillmentStatus String    @map("fulfillment_status")
  buyerName         String?   @map("buyer_name")
  buyerUsername     String?   @map("buyer_username")
  buyerCountry      String?   @map("buyer_country")
  totalAmount       Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  currency          String    @default("USD")
  orderDate         DateTime  @map("order_date")
  paidAt            DateTime? @map("paid_at")
  modifiedAt        DateTime? @map("modified_at")
  shipByDate        DateTime? @map("ship_by_date")
  tags              String[]  @default([])
  warningLevel      String    @default("none") @map("warning_level")
  warningMessage    String?   @map("warning_message") @db.Text
  automationCheckedAt DateTime? @map("automation_checked_at")
  rawJson           Json      @map("raw_json")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ebayAccount EbayAccount? @relation(fields: [ebayAccountId], references: [id], onDelete: SetNull)
  items       OrderItem[]
  shipments   Shipment[]
  inventoryMovements InventoryMovement[]

  @@unique([ebayAccountId, ebayOrderId])
  @@index([userId, fulfillmentStatus])
  @@index([warningLevel])
  @@index([orderDate])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String   @map("order_id")
  productId  String?  @map("product_id")
  lineItemId String   @map("line_item_id")
  title      String
  sku        String?
  quantity   Int      @default(1)
  stockDeducted Boolean @default(false) @map("stock_deducted")
  matchedBy  String?  @map("matched_by")
  matchScore Float?   @map("match_score")
  rawJson    Json?    @map("raw_json")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([orderId, lineItemId])
  @@index([sku])
  @@index([productId])
  @@index([stockDeducted])
  @@map("order_items")
}

model Product {
  id            String   @id @default(cuid())
  sku           String   @unique
  internalCode  String?  @map("internal_code")
  productName   String   @map("product_name")
  optionName    String?  @map("option_name")
  category      String?
  brand         String?
  costPrice     Decimal? @map("cost_price") @db.Decimal(12, 2)
  salePrice     Decimal? @map("sale_price") @db.Decimal(12, 2)
  stockQuantity Int      @default(0) @map("stock_quantity")
  safetyStock   Int      @default(0) @map("safety_stock")
  location      String?
  memo          String?  @db.Text
  imageUrl      String?  @map("image_url")
  status        String   @default("active")
  ebayTitle      String?  @map("ebay_title")
  descriptionHtml String? @map("description_html") @db.Text
  ebayPrice      Decimal? @map("ebay_price") @db.Decimal(12, 2)
  ebayImageUrls  String[] @default([]) @map("ebay_image_urls")
  ebayCategoryId String?  @map("ebay_category_id")
  ebayCondition  String?  @map("ebay_condition")
  ebayShippingProfile String? @map("ebay_shipping_profile")
  ebayReturnProfile String? @map("ebay_return_profile")
  ebayPaymentProfile String? @map("ebay_payment_profile")
  ebayMerchantLocationKey String? @map("ebay_merchant_location_key")
  ebayMarketplaceId String? @map("ebay_marketplace_id")
  ebayCurrency String? @map("ebay_currency")
  ebayOfferId String? @map("ebay_offer_id")
  ebayItemId  String? @map("ebay_item_id")
  listingStatus String? @map("listing_status")
  lastUploadedAt DateTime? @map("last_uploaded_at")
  uploadError String? @map("upload_error") @db.Text
  uploadErrorSummary String? @map("upload_error_summary") @db.Text
  uploadRawError Json? @map("upload_raw_error")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  orderItems OrderItem[]
  movements  InventoryMovement[]
  mappings   ProductMapping[]
  uploadJobs ProductUploadJob[]
  listingDrafts ListingDraft[]
  listingLinks InventoryListingLink[]

  @@index([status])
  @@index([stockQuantity])
  @@index([productName])
  @@index([listingStatus])
  @@index([ebayItemId])
  @@map("products")
}

model ProductUploadJob {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  productId   String?  @map("product_id")
  templateId  String?  @map("template_id")
  sku         String
  source      String   @default("single")
  action      String?
  status      String   @default("pending")
  message     String?  @db.Text
  error       String?  @db.Text
  errorSummary String? @map("error_summary") @db.Text
  rawEbayError Json?   @map("raw_ebay_error")
  rawJson     Json?    @map("raw_json")
  finalPayloadJson Json? @map("final_payload_json")
  startedAt   DateTime? @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  template ListingTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([productId])
  @@index([templateId])
  @@index([sku])
  @@map("product_upload_jobs")
}

model ListingTemplate {
  id                       String   @id @default(cuid())
  userId                   String   @map("user_id")
  name                     String
  description              String?  @db.Text
  marketplaceId            String?  @map("marketplace_id")
  categoryId               String?  @map("category_id")
  condition                String?
  conditionDescription     String?  @map("condition_description") @db.Text
  listingDuration          String?  @map("listing_duration")
  listingFormat            String?  @map("listing_format")
  currency                 String?
  defaultQuantity          Int?     @map("default_quantity")
  defaultPrice             Decimal? @map("default_price") @db.Decimal(12, 2)
  paymentPolicyId          String?  @map("payment_policy_id")
  fulfillmentPolicyId      String?  @map("fulfillment_policy_id")
  returnPolicyId           String?  @map("return_policy_id")
  merchantLocationKey      String?  @map("merchant_location_key")
  bestOfferEnabled         Boolean  @default(false) @map("best_offer_enabled")
  minimumOfferPrice        Decimal? @map("minimum_offer_price") @db.Decimal(12, 2)
  autoAcceptPrice          Decimal? @map("auto_accept_price") @db.Decimal(12, 2)
  privateListing           Boolean  @default(false) @map("private_listing")
  immediatePayRequired     Boolean  @default(false) @map("immediate_pay_required")
  descriptionTemplateHtml  String?  @map("description_template_html") @db.Text
  itemSpecificsTemplateJson Json?   @map("item_specifics_template_json")
  imageSettingsJson        Json?    @map("image_settings_json")
  shippingSettingsJson     Json?    @map("shipping_settings_json")
  skuSettingsJson          Json?    @map("sku_settings_json")
  titleTemplate            String?  @map("title_template")
  excludedLocationsJson    Json?    @map("excluded_locations_json")
  isDefault                Boolean  @default(false) @map("is_default")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadJobs ProductUploadJob[]
  listingDrafts ListingDraft[]

  @@index([userId, isDefault])
  @@index([userId, name])
  @@map("listing_templates")
}

model ProductMapping {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  productId       String   @map("product_id")
  ebayItemId      String?  @map("ebay_item_id")
  ebayVariationId String?  @map("ebay_variation_id")
  normalizedTitle String?  @map("normalized_title") @db.Text
  source          String   @default("manual")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId, ebayItemId, ebayVariationId])
  @@index([userId, ebayItemId])
  @@index([userId, normalizedTitle])
  @@index([productId])
  @@map("product_mappings")
}

model ListingDraft {
  id                   String    @id @default(cuid())
  userId               String    @map("user_id")
  sourceInventoryId    String?   @map("source_inventory_id")
  templateId           String?   @map("template_id")
  sku                  String
  title                String
  subtitle             String?
  descriptionHtml      String?   @map("description_html") @db.Text
  price                Decimal?  @db.Decimal(12, 2)
  quantity             Int?
  imageUrlsJson        Json?     @map("image_urls_json")
  categoryId           String?   @map("category_id")
  condition            String?
  conditionDescription String?   @map("condition_description") @db.Text
  itemSpecificsJson    Json?     @map("item_specifics_json")
  marketplaceId        String?   @map("marketplace_id")
  currency             String?
  paymentPolicyId      String?   @map("payment_policy_id")
  fulfillmentPolicyId  String?   @map("fulfillment_policy_id")
  returnPolicyId       String?   @map("return_policy_id")
  merchantLocationKey  String?   @map("merchant_location_key")
  bestOfferEnabled     Boolean   @default(false) @map("best_offer_enabled")
  minimumOfferPrice    Decimal?  @map("minimum_offer_price") @db.Decimal(12, 2)
  autoAcceptPrice      Decimal?  @map("auto_accept_price") @db.Decimal(12, 2)
  privateListing       Boolean   @default(false) @map("private_listing")
  immediatePayRequired Boolean   @default(false) @map("immediate_pay_required")
  listingFormat        String?   @map("listing_format")
  status               String    @default("draft")
  ebayItemId           String?   @map("ebay_item_id")
  offerId              String?   @map("offer_id")
  listingStatus        String?   @map("listing_status")
  errorSummary         String?   @map("error_summary") @db.Text
  rawErrorJson         Json?     @map("raw_error_json")
  validationJson       Json?     @map("validation_json")
  fieldSourceJson      Json?     @map("field_source_json")
  lastUploadedAt       DateTime? @map("last_uploaded_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceInventory Product?          @relation(fields: [sourceInventoryId], references: [id], onDelete: SetNull)
  template        ListingTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId, status, updatedAt])
  @@index([sourceInventoryId])
  @@index([templateId])
  @@index([sku])
  @@map("listing_drafts")
}

model EbayPolicyCache {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  policyType    String   @map("policy_type")
  policyId      String   @map("policy_id")
  name          String?
  marketplaceId String?  @map("marketplace_id")
  rawJson       Json?    @map("raw_json")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, policyType, policyId, marketplaceId])
  @@index([userId, policyType, marketplaceId])
  @@map("ebay_policy_caches")
}

model EbayInventoryLocationCache {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  merchantLocationKey String   @map("merchant_location_key")
  name                String?
  addressSummary      String?  @map("address_summary")
  rawJson             Json?    @map("raw_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantLocationKey])
  @@index([userId, name])
  @@map("ebay_inventory_location_caches")
}

model InventoryListingLink {
  id             String    @id @default(cuid())
  inventoryId    String    @map("inventory_id")
  sku            String
  ebayItemId     String?   @map("ebay_item_id")
  offerId        String?   @map("offer_id")
  listingStatus  String?   @map("listing_status")
  lastUploadedAt DateTime? @map("last_uploaded_at")
  lastSyncedAt   DateTime? @map("last_synced_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  inventory Product @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@unique([inventoryId])
  @@index([sku])
  @@index([listingStatus])
  @@map("inventory_listing_links")
}

model InventoryMovement {
  id             String   @id @default(cuid())
  productId      String   @map("product_id")
  type           String
  quantity       Int
  beforeQuantity Int      @map("before_quantity")
  afterQuantity  Int      @map("after_quantity")
  reason         String?
  relatedOrderId String?  @map("related_order_id")
  createdBy      String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  relatedOrder Order?  @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([type])
  @@index([relatedOrderId])
  @@map("inventory_movements")
}

model Shipment {
  id                String         @id @default(cuid())
  orderId           String         @map("order_id")
  carrierCode       String         @map("carrier_code")
  trackingNumber    String         @map("tracking_number")
  shippedAt         DateTime       @default(now()) @map("shipped_at")
  ebayFulfillmentId String?        @map("ebay_fulfillment_id")
  status            ShipmentStatus @default(PENDING)
  rawJson           Json?          @map("raw_json")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, trackingNumber])
  @@index([status])
  @@map("shipments")
}

model SyncLog {
  id        String     @id @default(cuid())
  userId    String?    @map("user_id")
  type      String
  status    SyncStatus
  message   String     @db.Text
  rawJson   Json?      @map("raw_json")
  createdAt DateTime   @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, status])
  @@index([createdAt])
  @@map("sync_logs")
}
